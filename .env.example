# Required: GitHub Search API access
GITHUB_TOKEN=

# Required: DeepSeek summary generation
DEEPSEEK_API_KEY=

# Required: Telegram delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: public page URLs used in outgoing messages
PUBLIC_HISTORY_URL=
PUBLIC_WEEKLY_URL=

# Optional: how many repos to notify per run
TOP_N=3

# Optional: comma-separated local notify times
NOTIFY_TIMES=09:00,20:00

# Optional: local timezone for scheduling
TIMEZONE=Asia/Tokyo

# Optional: comma-separated GitHub search themes
TOPICS=ai,cli,automation

# Optional: collection profile. Use "gray" for legally-edgy repo ranking.
COLLECTION_PROFILE=general

# Optional: comma-separated GitHub Search sort keys.
GITHUB_SEARCH_SORTS=stars,updated

# Optional: cap gray-mode GitHub Search terms to avoid Search API throttling.
GRAY_SEARCH_TERM_LIMIT=16

# Optional: minimum GitHub stars for candidate repos
MIN_STARS=30

# Optional: suppress repeat notifications for this many days
COOLDOWN_DAYS=14

# Optional: low-stars / high-score archive thresholds
LOW_STAR_HIGH_SCORE_MAX_STARS=1000
LOW_STAR_HIGH_SCORE_MIN_SCORE=70
LOW_STAR_HIGH_SCORE_LIMIT=6
